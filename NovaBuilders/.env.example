# ─────────────────────────────────────────────────────────────
#  Nova Builders — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# App environment
NODE_ENV=development

# Optional: Sentry DSN for crash reporting
# SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# Optional: analytics
# ANALYTICS_KEY=your-key-here
